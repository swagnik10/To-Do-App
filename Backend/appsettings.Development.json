{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "%LOCALAPPDATA%\\TodoApi\\logs\\log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=<Host_Name>;Port=<Port_Number>;Database=<Db_Name>;Username=<User_Name>;Password=<Password>;SSL Mode=Require;Trust Server Certificate=true;"
  },
  "Gemini": {
    "ApiKey": "API_KEY",
    "Model": "API_MODEL"
  },
  "AllowedHosts": "*"
}
